# MassIVE/GNPS open-format index record.
OPENFORMATS_RECORD_ID=4549746
OPENFORMATS_INDEX_DIR=data/openformats

# Local persistent state.
STATE_DATABASE_URL=data/gnps_massive_to_mgf.sqlite

# Raw open-format downloads and generated MGF shards.
MZML_DOWNLOAD_DIR=/mnt/bfd/mzml
MGF_OUTPUT_DIR=/mnt/bfd/mgf

# Initial corpus target and conversion policy.
TARGET_MS2_SPECTRA=200000000
TOP_K_PEAKS=256
MGF_SHARD_MAX_SPECTRA=1000000
SOURCE_SELECTION_BUFFER=1.25
SOURCE_SELECTION_CHUNK_MS2=50000000

# Concurrent MassIVE transfers. Keep this at 1 for initial production runs.
DOWNLOAD_WORKERS=1
DOWNLOAD_RETRY_ATTEMPTS=5
DOWNLOAD_RETRY_DELAY_SECONDS=30
# Set to 0 to disable the full-transfer timeout for very large files.
HTTP_REQUEST_TIMEOUT_SECONDS=600
HTTP_CONNECT_TIMEOUT_SECONDS=30

# Optional production publication. If ZENODO_TOKEN is present, the pipeline
# publishes to production. Existing depositions are reused when this is set.
ZENODO_TOKEN=
ZENODO_DEPOSITION_ID=
ZENODO_MAX_FILE_BYTES=50000000000
